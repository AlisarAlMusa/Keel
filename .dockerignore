# Shared root build context for Dockerfile.api and Dockerfile.worker.
# Keep the backend image lean and free of unrelated trees.

.git
.github
.venv
**/__pycache__
*.pyc
.mypy_cache
.ruff_cache
.pytest_cache
.coverage
htmlcov

# Other build contexts / unrelated code
model-server

# Phase 5 frontend — allow ui/, widget/, admin/, static/ into the api build
# context so Dockerfile.api node-builder stage can compile them.
# Exclude portal/ (has its own container), node_modules, and pre-built dist/.
frontend/portal
frontend/**/node_modules
frontend/**/dist
node_modules

# Docs & specs (not needed at runtime)
specs
docs
*.md
!README.md
!data/
Keel_Brief.pdf

# Local env / secrets
.env
.env.*
!.env.example
