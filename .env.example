# Keel — example environment. Copy to .env. NO REAL SECRETS HERE.
# Secret *values* are resolved from Vault at startup (see VAULT_* below);
# this file carries only non-secret config + how to reach Vault.

# --- App ---
KEEL_ENV=local                       # environment name: local | ci | prod
KEEL_LOG_LEVEL=INFO                  # log level
KEEL_API_PORT=8000                   # api bind port

# --- Datastores (non-secret connection info; password comes from Vault) ---
DATABASE_URL=postgresql+asyncpg://keel_app:placeholder@db:5432/keel
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000     # object store endpoint
MINIO_BUCKET=keel-artifacts          # default bucket

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Tracing / observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=         # empty => tracing degrades gracefully
OTEL_SERVICE_NAME=keel-api
LANGSMITH_TRACING=false              # enable LangSmith (later phases)

# --- Model server ---
MODEL_SERVER_URL=http://model-server:9000

# --- Vault coordinates (how to REACH Vault; not secrets themselves) ---
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=keel-dev-root-token      # dev-mode token, LOCAL ONLY
VAULT_KV_MOUNT=secret                # KV v2 mount
VAULT_SECRET_PATH=keel/app           # path holding app secrets

# Secrets stored IN Vault at VAULT_KV_MOUNT/VAULT_SECRET_PATH (NOT here):
#   db_password, minio_access_key, minio_secret_key,
#   jwt_signing_key, widget_token_secret, langsmith_api_key
