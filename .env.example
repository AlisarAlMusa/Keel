# Keel — copy this file to .env and fill in real values.
# .env is gitignored. This file IS committed — no real secrets here.

# --- App runtime ---
KEEL_ENV=local
KEEL_LOG_LEVEL=INFO
KEEL_LOG_FILE=                         # volume-mounted path; empty = stdout only
DATABASE_URL=postgresql+asyncpg://keel_app:placeholder@db:5432/keel
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=keel-artifacts
MLFLOW_BUCKET=keel-mlflow
MLFLOW_TRACKING_URI=http://mlflow:5000
# Tracing: api + worker export OTLP to the in-stack Jaeger (UI at :16686).
# Leave empty to disable (spans still created, no exporter). Compose defaults
# this to http://jaeger:4317 when unset, so traces flow with no change here.
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=keel-api
LANGSMITH_TRACING=false
MODEL_SERVER_URL=http://model-server:9000

# --- Vault coordinates ---
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=change-me
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=keel/app

# --- Postgres (docker stack) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=keel
KEEL_APP_PASSWORD=change-me

# --- MinIO (docker stack) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# --- Secrets seeded into Vault by vault-init ---
KEEL_JWT_SIGNING_KEY=change-me
KEEL_WIDGET_TOKEN_SECRET=change-me
# Phase 5: shared secret between portal service and keel-api /internal/mint-token
# Generate with: openssl rand -hex 32
KEEL_PORTAL_SERVICE_SECRET=change-me
# G2: per-portal service secrets — each portal can mint ONLY its own tenant's
# widget tokens. If unset, they fall back to the shared secret above.
KEEL_PORTAL_SERVICE_SECRET_NORTHANE=change-me-northane
KEEL_PORTAL_SERVICE_SECRET_SUMMIT=change-me-summit

# G4: email/notifications. Email is ON for Keel actions (registration, waitlist,
# petition, graduation, major-change, escalation). SIS events (registrar approve/
# reject) never email. With SMTP disabled the send is SIMULATED (logged to the
# address below) — no real mail. Set KEEL_SMTP_ENABLED=true + host to send for real.
KEEL_EMAIL_ENABLED=true
KEEL_EMAIL_SIMULATE_TO=mousaelisar@gmail.com
KEEL_SMTP_ENABLED=false
KEEL_SMTP_HOST=
KEEL_SMTP_PORT=587
KEEL_SMTP_USER=
KEEL_SMTP_PASSWORD=
KEEL_SMTP_STARTTLS=true
KEEL_EMAIL_FROM=noreply@keel.local

# --- LLM models (names are not secret; API keys come from Vault) ---
# Fallback chain: strongest → high-quota → reserve.
#   Primary tried first; on 429/503, next fallback is used transparently.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=["gemini-3.1-flash-lite","gemini-3-flash"]
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# --- RAG / embedding knobs (all tuneable without code change) ---
EMBED_MODEL=embed-multilingual-v3.0
EMBED_DIM=1024
RERANK_MODEL=rerank-multilingual-v3.0
DENSE_K=20
SPARSE_K=20
RRF_K=60
RERANK_TOP_N=5

# --- Session ---
SESSION_TTL_SECONDS=1800

# --- Real API keys (fill in .env only — seeded into Vault by vault-init) ---
GEMINI_API_KEY=change-me
COHERE_API_KEY=change-me
# LANGSMITH_API_KEY=change-me
