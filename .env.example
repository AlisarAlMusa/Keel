# Keel — copy this file to .env and fill in real values.
# .env is gitignored. This file IS committed — no real secrets here.

# --- App runtime ---
KEEL_ENV=local
KEEL_LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://keel_app:placeholder@db:5432/keel
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=keel-artifacts
MLFLOW_TRACKING_URI=http://mlflow:5000
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=keel-api
LANGSMITH_TRACING=false
MODEL_SERVER_URL=http://model-server:9000

# --- Vault coordinates ---
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=change-me
VAULT_KV_MOUNT=secret
VAULT_SECRET_PATH=keel/app

# --- Postgres (docker stack) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=keel
KEEL_APP_PASSWORD=change-me

# --- MinIO (docker stack) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# --- Secrets seeded into Vault by vault-init ---
KEEL_JWT_SIGNING_KEY=change-me
KEEL_WIDGET_TOKEN_SECRET=change-me

# --- Real API keys (fill in .env only, never here) ---
# ANTHROPIC_API_KEY=
# LANGSMITH_API_KEY=
