{
  "name": "keel-frontend",
  "private": true,
  "workspaces": [
    "ui",
    "widget",
    "admin",
    "portal",
    "platform"
  ],
  "scripts": {
    "build": "npm run build --workspace=ui && npm run build --workspace=widget && npm run build --workspace=admin && npm run build --workspace=portal && npm run build --workspace=platform",
    "build:ui": "npm run build --workspace=ui",
    "build:widget": "npm run build --workspace=widget",
    "build:admin": "npm run build --workspace=admin",
    "build:portal": "npm run build --workspace=portal",
    "build:platform": "npm run build --workspace=platform",
    "dev:widget": "npm run dev --workspace=widget",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:portal": "npm run dev --workspace=portal",
    "dev:platform": "npm run dev --workspace=platform"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
